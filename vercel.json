{
  "buildCommand": "cd frontend-react && npm install && npm run build",
  "outputDirectory": "frontend-react/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stockstracker.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "stockstracker": {
      "type": "web",
      "routePrefix": "/",
      "buildCommand": "pip install -r requirements.txt"
    }
  }
}
